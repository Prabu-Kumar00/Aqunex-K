  <!-- Technical Specifications Section -->
  <section class="specifications-section">
    <div class="specifications-container">
      <h2>📋 Technical Specifications</h2>
      <p class="subtitle">Detailed specifications for R-TECH autonomous water monitoring robot</p>

      <div class="specs-table-wrapper">
        <table class="specs-table">
          <thead>
            <tr>
              <th>Sl No.</th>
              <th>Parameter</th>
              <th>Specifications</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>1.</td>
              <td>Mission Duration</td>
              <td>3-4 hours continuous operation per charge cycle</td>
            </tr>

            <tr>
              <td>2.</td>
              <td>Deployment Area</td>
              <td>Rivers, estuaries, coastal areas, and inland water bodies across India</td>
            </tr>

            <tr class="nested-row">
              <td>3.</td>
              <td>Sensor Payloads</td>
              <td>
                <strong>Water Quality Sensors:</strong>
                <ol>
                  <li>pH Sensor (E201-C BNC electrode)</li>
                  <li>Temperature Sensor (DS18B20 - Waterproof)</li>
                  <li>Turbidity Sensor</li>
                  <li>Spectral Sensors (AS7265x) for chlorophyll-a measurement</li>
                </ol>
                <strong>Environmental Monitoring:</strong>
                <ol start="6">
                  <li>Camera Module for plastic detection (with YOLO ML model)</li>
                  <li>GPS Module for location tracking</li>
                  <li>IMU (Inertial Measurement Unit) for navigation</li>
                </ol>
              </td>
            </tr>

            <tr class="nested-row">
              <td>4.</td>
              <td>Robot Configuration</td>
              <td>
                <ol>
                  <li><strong>Catamaran Hull:</strong> Triple pontoon design for stability</li>
                  <li><strong>Propulsion System:</strong> Dual DC motors (775 motors) with 3D-printed propellers</li>
                  <li><strong>Control Unit:</strong> ESP32 for data processing</li>
                  <li><strong>ML Processing:</strong> Jetson Orin Nano for real-time AI inference</li>
                </ol>
              </td>
            </tr>

            <tr class="nested-row">
              <td>5.</td>
              <td>Data Processing</td>
              <td>
                <ol>
                  <li><strong>Edge Computing:</strong> Jetson Orin Nano for sensor data aggregation</li>
                  <li><strong>Machine Learning:</strong> YOLO v8 for plastic detection</li>
                  <li><strong>Spectral Analysis:</strong> Simple algorithms for chlorophyll-a concentration calculation</li>
                  <li><strong>Real-time Dashboard:</strong> React.js frontend with Leaflet.js for map visualization</li>
                </ol>
              </td>
            </tr>

            <tr class="nested-row">
              <td>6.</td>
              <td>Environmental Ratings</td>
              <td>
                <ol>
                  <li><strong>Water Resistance:</strong> IP67 rated electronics enclosure</li>
                  <li><strong>Operating Temperature:</strong> 10°C to 45°C</li>
                  <li><strong>Wave Tolerance:</strong> Up to 0.5m wave height</li>
                  <li><strong>Wind Speed:</strong> Up to 40 km/h</li>
                </ol>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

