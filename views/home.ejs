<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>R-TECH | Water Quality Monitoring Platform</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/home.css">

  <style>
    /* ══════════════════════════════════════════════
       GLOBAL ENHANCEMENTS
    ══════════════════════════════════════════════ */
    :root {
      --ocean-1: #0ea5e9;
      --ocean-2: #6366f1;
      --ocean-3: #8b5cf6;
      --ocean-4: #06b6d4;
      --glow-blue:   0 0 40px rgba(14,165,233,0.25);
      --glow-purple: 0 0 40px rgba(139,92,246,0.25);
    }

    * { scroll-behavior: smooth; }

    body {
      background: #060d1a !important;
      color: #f1f5f9 !important;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── ANIMATED BG ─────────────────────────────── */
    .bg-gradient {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse 80% 60% at 10% 10%, rgba(14,165,233,0.12) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 90% 80%, rgba(139,92,246,0.1) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 50% 50%, rgba(6,182,212,0.05) 0%, transparent 70%),
        #060d1a;
      animation: bgShift 12s ease-in-out infinite alternate;
    }
    @keyframes bgShift {
      from { opacity: 1; }
      to   { filter: hue-rotate(15deg) brightness(1.08); }
    }

    /* ── PARTICLES CANVAS ────────────────────────── */
    #particlesCanvas {
      position: fixed; inset: 0; z-index: 0;
      pointer-events: none; opacity: 0.4;
    }

    /* ── NAVBAR ──────────────────────────────────── */
    .navbar {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2.5rem;
      background: rgba(6,13,26,0.7);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(14,165,233,0.12);
      transition: all 0.3s ease;
    }
    .navbar.scrolled {
      padding: 0.65rem 2.5rem;
      background: rgba(6,13,26,0.92);
      border-bottom-color: rgba(14,165,233,0.2);
      box-shadow: 0 4px 30px rgba(0,0,0,0.4);
    }
    .logo {
      display: flex; align-items: center; gap: 0.6rem;
      font-size: 1.4rem; font-weight: 800; font-family: 'Outfit', sans-serif;
      background: linear-gradient(135deg, var(--ocean-1), var(--ocean-3));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      letter-spacing: -0.5px;
    }
    .nav-links { display: flex; gap: 0.75rem; }

    /* ── HERO ────────────────────────────────────── */
    .hero-carousel {
      position: relative; z-index: 1;
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .hero-slide { width: 100%; }
    .hero-content {
      position: relative;
      text-align: center;
      padding: 4rem 2rem;
      max-width: 900px;
      margin: 0 auto;
    }

    .hero-orb {
      position: absolute; border-radius: 50%; filter: blur(80px);
      animation: orbFloat 8s ease-in-out infinite;
      pointer-events: none;
    }
    .hero-orb-1 {
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(14,165,233,0.18) 0%, transparent 70%);
      top: -100px; left: 50%; transform: translateX(-50%);
      animation-delay: 0s;
    }
    .hero-orb-2 {
      width: 300px; height: 300px;
      background: radial-gradient(circle, rgba(139,92,246,0.14) 0%, transparent 70%);
      top: 100px; right: 100px;
      animation-delay: -3s;
    }
    .hero-orb-3 {
      width: 250px; height: 250px;
      background: radial-gradient(circle, rgba(6,182,212,0.12) 0%, transparent 70%);
      bottom: 50px; left: 100px;
      animation-delay: -6s;
    }
    @keyframes orbFloat {
      0%, 100% { transform: translateY(0px) translateX(0px); }
      33%       { transform: translateY(-30px) translateX(15px); }
      66%       { transform: translateY(15px) translateX(-10px); }
    }

    .hero-wave-line {
      display: inline-block;
      width: 60px; height: 3px;
      background: linear-gradient(90deg, var(--ocean-1), var(--ocean-3));
      border-radius: 2px;
      margin: 0 1rem;
      animation: wavePulse 2s ease-in-out infinite;
    }
    @keyframes wavePulse {
      0%, 100% { opacity: 0.5; width: 40px; }
      50%       { opacity: 1;   width: 70px; }
    }

    .hero-tag {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(14,165,233,0.1);
      border: 1px solid rgba(14,165,233,0.25);
      color: var(--ocean-1);
      padding: 0.4rem 1rem; border-radius: 100px;
      font-size: 0.82rem; font-weight: 600;
      letter-spacing: 1px; text-transform: uppercase;
      margin-bottom: 1.5rem;
      animation: fadeSlideDown 0.8s ease forwards;
    }
    .tag-dot {
      width: 6px; height: 6px; background: var(--ocean-1);
      border-radius: 50%; animation: tagBlink 1.5s infinite;
    }
    @keyframes tagBlink { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

    .hero-title {
      font-family: 'Outfit', sans-serif;
      font-size: clamp(3.5rem, 8vw, 6.5rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -2px;
      margin-bottom: 0.5rem;
      background: linear-gradient(135deg, #ffffff 0%, #bae6fd 40%, var(--ocean-3) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      animation: fadeSlideUp 1s ease 0.2s both;
    }
    .hero-subtitle {
      font-size: 1.15rem; font-weight: 600;
      color: var(--ocean-1); letter-spacing: 2px;
      text-transform: uppercase; margin-bottom: 1.5rem;
      animation: fadeSlideUp 1s ease 0.4s both;
    }
    .hero-desc {
      font-size: 1.1rem; line-height: 1.8;
      color: #94a3b8; max-width: 700px;
      margin: 0 auto 2.5rem;
      animation: fadeSlideUp 1s ease 0.6s both;
    }
    .hero-cta-row {
      display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;
      animation: fadeSlideUp 1s ease 0.8s both;
    }

    /* ── HERO STATS BAR ──────────────────────────── */
    .hero-stats {
      position: relative; z-index: 1;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1px;
      max-width: 900px; margin: 0 auto 5rem;
      background: rgba(14,165,233,0.1);
      border: 1px solid rgba(14,165,233,0.15);
      border-radius: 20px; overflow: hidden;
      backdrop-filter: blur(10px);
      animation: fadeSlideUp 1s ease 1s both;
    }
    .hero-stat-item {
      padding: 1.5rem;
      background: rgba(6,13,26,0.6);
      text-align: center;
      transition: background 0.3s;
    }
    .hero-stat-item:hover { background: rgba(14,165,233,0.08); }
    .hero-stat-num {
      font-size: 2rem; font-weight: 800; font-family: 'Outfit', sans-serif;
      background: linear-gradient(135deg, var(--ocean-1), var(--ocean-3));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .hero-stat-label { font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-top: 3px; }

    /* ── WAVE DIVIDER ────────────────────────────── */
    .wave-divider { position: relative; overflow: hidden; height: 80px; margin-bottom: -2px; }
    .wave-divider svg { position: absolute; bottom: 0; width: 100%; }

    /* ── SECTION FADE-IN ─────────────────────────── */
    .reveal {
      opacity: 0; transform: translateY(40px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-left  { opacity:0; transform: translateX(-40px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal-right { opacity:0; transform: translateX(40px);  transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal-left.visible, .reveal-right.visible { opacity:1; transform: translateX(0); }

    /* ══════════════════════════════════════════════
       TECH GRID — CSS Grid with full !important
       override to beat any conflicting home.css rules
    ══════════════════════════════════════════════ */
    .project-overview {
      position: relative; z-index: 1;
      padding: 5rem 2rem;
    }
    .project-container { max-width: 1200px; margin: 0 auto; }
    .project-container h2 {
      text-align: center; font-size: 2.5rem; font-weight: 800; font-family: 'Outfit', sans-serif;
      background: linear-gradient(135deg, #fff, #94a3b8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      margin-bottom: 0.5rem;
    }
    .project-container .subtitle {
      text-align: center; color: #64748b; margin-bottom: 3.5rem; font-size: 1rem;
    }

    .tech-grid {
      display: grid !important;
      grid-template-columns: repeat(4, 1fr) !important;
      gap: 1.25rem !important;
      /* Reset any flex properties from home.css */
      flex-wrap: unset !important;
      flex-direction: unset !important;
      align-items: unset !important;
    }
    @media (max-width: 900px) {
      .tech-grid { grid-template-columns: repeat(2, 1fr) !important; }
    }
    @media (max-width: 500px) {
      .tech-grid { grid-template-columns: 1fr !important; }
    }

    .tech-card {
      background: rgba(255,255,255,0.03) !important;
      border: 1px solid rgba(255,255,255,0.07) !important;
      border-radius: 18px !important;
      padding: 1.75rem !important;
      transition: all 0.35s ease !important;
      position: relative !important;
      overflow: hidden !important;
      /* Reset any flex-child properties from home.css */
      flex: unset !important;
      min-width: unset !important;
      width: unset !important;
    }
    .tech-card::before {
      content: ''; position: absolute;
      inset: 0; border-radius: 18px; opacity: 0;
      background: linear-gradient(135deg, rgba(14,165,233,0.07), rgba(139,92,246,0.07));
      transition: opacity 0.35s ease;
    }
    .tech-card:hover { transform: translateY(-8px); border-color: rgba(14,165,233,0.3) !important; box-shadow: var(--glow-blue); }
    .tech-card:hover::before { opacity: 1; }
    .tech-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; color: #e2e8f0; }
    .tech-card ul { list-style: none; padding: 0; }
    .tech-card ul li {
      padding: 0.4rem 0; color: #94a3b8; font-size: 0.88rem;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      display: flex; align-items: center; gap: 0.5rem;
    }
    .tech-card ul li:last-child { border: none; }
    .tech-card ul li::before { content: '▸'; color: var(--ocean-1); font-size: 0.7rem; flex-shrink: 0; }

    /* ── SPECS TABLE ─────────────────────────────── */
    .specifications-section {
      position: relative; z-index: 1;
      background: rgba(255,255,255,0.015);
      border-top: 1px solid rgba(255,255,255,0.06);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 5rem 2rem;
    }
    .specifications-container { max-width: 1100px; margin: 0 auto; }
    .specifications-container h2, .specifications-container .subtitle { text-align: center; margin-bottom: 0.5rem; }
    .specifications-container h2 {
      font-size: 2.5rem; font-weight: 800;
      background: linear-gradient(135deg, #fff, #94a3b8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .specifications-container .subtitle { color: #64748b; margin-bottom: 3rem; }
    .specs-table-wrapper {
      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 18px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .specs-table { width: 100%; border-collapse: collapse; }
    .specs-table thead tr { background: rgba(14,165,233,0.08); }
    .specs-table th {
      padding: 1rem 1.5rem; text-align: left; font-size: 0.78rem;
      text-transform: uppercase; letter-spacing: 1.5px;
      color: var(--ocean-1); font-weight: 700;
      border-bottom: 1px solid rgba(14,165,233,0.15);
    }
    .specs-table td {
      padding: 1rem 1.5rem; color: #cbd5e1; font-size: 0.9rem;
      border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: top;
    }
    .specs-table tbody tr { transition: background 0.2s; }
    .specs-table tbody tr:hover { background: rgba(14,165,233,0.04); }
    .specs-table tbody tr:last-child td { border-bottom: none; }
    .specs-table ol { padding-left: 1.2rem; margin: 0.5rem 0; }
    .specs-table ol li { margin: 0.3rem 0; line-height: 1.6; }
    .nested-row td:first-child { color: var(--ocean-1); font-weight: 700; }

    /* ── PROTOTYPE GALLERY ───────────────────────── */
    .prototype-section { position: relative; z-index: 1; padding: 5rem 2rem; }
    .prototype-container { max-width: 1200px; margin: 0 auto; }
    .prototype-container h2 {
      text-align: center; font-size: 2.5rem; font-weight: 800;
      background: linear-gradient(135deg, #fff, #94a3b8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem;
    }
    .prototype-container .subtitle { text-align: center; color: #64748b; margin-bottom: 1rem; }
    .prototype-gallery {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem; margin-top: 2.5rem;
    }
    .prototype-card {
      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 18px; overflow: hidden; transition: all 0.35s ease;
    }
    .prototype-card:hover { transform: translateY(-8px) scale(1.01); border-color: rgba(14,165,233,0.3); box-shadow: var(--glow-blue); }
    .prototype-card img { width: 100%; height: 220px; object-fit: cover; transition: transform 0.5s ease; }
    .prototype-card:hover img { transform: scale(1.06); }
    .prototype-info { padding: 1.25rem 1.5rem; }
    .prototype-info h3 { font-size: 0.95rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.4rem; }
    .prototype-info p  { font-size: 0.82rem; color: #64748b; line-height: 1.6; }

    /* ── TEAM SECTION ────────────────────────────── */
    .team-section {
      position: relative; z-index: 1;
      background: rgba(255,255,255,0.015);
      border-top: 1px solid rgba(255,255,255,0.06); padding: 5rem 2rem;
    }
    .team-container { max-width: 1200px; margin: 0 auto; }
    .team-container h2 {
      text-align: center; font-size: 2.5rem; font-weight: 800;
      background: linear-gradient(135deg, #fff, #94a3b8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem;
    }
    .team-container .subtitle { text-align: center; color: #64748b; margin-bottom: 3rem; }
    .team-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.25rem; }
    .team-card {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px; padding: 1.75rem 1.25rem; text-align: center;
      transition: all 0.35s ease; position: relative; overflow: hidden;
    }
    .team-card::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--ocean-1), var(--ocean-3));
      transform: scaleX(0); transform-origin: center; transition: transform 0.35s ease;
    }
    .team-card:hover { transform: translateY(-8px); border-color: rgba(14,165,233,0.3); box-shadow: var(--glow-blue); background: rgba(14,165,233,0.04); }
    .team-card:hover::after { transform: scaleX(1); }
    .team-photo {
      width: 84px; height: 84px; border-radius: 50%; overflow: hidden;
      margin: 0 auto 1rem; border: 2px solid rgba(14,165,233,0.3);
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .team-card:hover .team-photo { border-color: var(--ocean-1); box-shadow: 0 0 20px rgba(14,165,233,0.3); }
    .team-photo img { width: 100%; height: 100%; object-fit: cover; }
    .team-card h3 { font-size: 0.92rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.3rem; }
    .team-card .role { font-size: 0.75rem; color: #64748b; margin-bottom: 1rem; line-height: 1.4; }
    .team-card .affiliation { font-size: 0.72rem; color: #475569; margin-bottom: 0.75rem; }
    .mentor-card { max-width: 260px; }
    .linkedin-btn {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.45rem 1rem; border-radius: 8px; font-size: 0.78rem;
      font-weight: 600; color: #e2e8f0; text-decoration: none;
      background: rgba(14,165,233,0.1); border: 1px solid rgba(14,165,233,0.2);
      transition: all 0.25s ease;
    }
    .linkedin-btn:hover { background: rgba(14,165,233,0.2); border-color: var(--ocean-1); color: var(--ocean-1); transform: translateY(-1px); }

    /* ── PROBLEM SECTION ─────────────────────────── */
    .problem-section { position: relative; z-index: 1; padding: 5rem 2rem; }
    .problem-container { max-width: 1200px; margin: 0 auto; }
    .problem-container h2 {
      text-align: center; font-size: 2.5rem; font-weight: 800;
      background: linear-gradient(135deg, #fff, #94a3b8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem;
    }
    .problem-container .subtitle { text-align: center; color: #64748b; margin-bottom: 3rem; }
    .problem-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 1.5rem; }
    .problem-card {
      background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 20px; overflow: hidden; transition: all 0.35s ease;
    }
    .problem-card:hover { transform: translateY(-6px); border-color: rgba(239,68,68,0.3); box-shadow: 0 0 40px rgba(239,68,68,0.1); }
    .problem-card img { width: 100%; height: 200px; object-fit: cover; }
    .problem-content { padding: 1.5rem; }
    .location-badge {
      display: inline-block; background: rgba(14,165,233,0.1); border: 1px solid rgba(14,165,233,0.2);
      color: var(--ocean-1); padding: 0.3rem 0.75rem; border-radius: 100px; font-size: 0.72rem; font-weight: 600; margin-bottom: 0.75rem;
    }
    .problem-content h3 { font-size: 1rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.5rem; }
    .problem-content p  { font-size: 0.88rem; color: #94a3b8; margin-bottom: 0.5rem; line-height: 1.7; }
    .impact-list { list-style: none; padding: 0; margin: 0.5rem 0 0; }
    .impact-list li { font-size: 0.82rem; color: #94a3b8; padding: 0.3rem 0; line-height: 1.5; }

    /* ── FEATURES ────────────────────────────────── */
    .features-section {
      position: relative; z-index: 1; background: rgba(255,255,255,0.015);
      border-top: 1px solid rgba(255,255,255,0.06); padding: 5rem 2rem;
    }
    .features-section h2 {
      text-align: center; font-size: 2.5rem; font-weight: 800;
      background: linear-gradient(135deg, #fff, #94a3b8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 3rem;
    }
    .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem; max-width: 1100px; margin: 0 auto; }
    .feature-card {
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 18px; padding: 2rem 1.5rem; text-align: center; transition: all 0.35s ease;
      position: relative; overflow: hidden;
    }
    .feature-card::before {
      content: ''; position: absolute; inset: 0; border-radius: 18px;
      background: linear-gradient(135deg, rgba(14,165,233,0.06), rgba(139,92,246,0.06));
      opacity: 0; transition: opacity 0.35s;
    }
    .feature-card:hover { transform: translateY(-8px); border-color: rgba(14,165,233,0.3); box-shadow: var(--glow-blue); }
    .feature-card:hover::before { opacity: 1; }
    .feature-card .icon { font-size: 2.5rem; margin-bottom: 1rem; display: block; animation: iconBob 3s ease-in-out infinite; }
    @keyframes iconBob { 0%,100%{ transform: translateY(0); } 50% { transform: translateY(-6px); } }
    .feature-card:nth-child(2) .icon { animation-delay: -0.75s; }
    .feature-card:nth-child(3) .icon { animation-delay: -1.5s; }
    .feature-card:nth-child(4) .icon { animation-delay: -2.25s; }
    .feature-card h3 { font-size: 1rem; font-weight: 700; color: #e2e8f0; margin-bottom: 0.5rem; }
    .feature-card p  { font-size: 0.85rem; color: #64748b; line-height: 1.6; }

    /* ── CTA ─────────────────────────────────────── */
    .cta-section {
      position: relative; z-index: 1; text-align: center; padding: 6rem 2rem;
      background: linear-gradient(135deg, rgba(14,165,233,0.06) 0%, rgba(139,92,246,0.06) 50%, rgba(6,182,212,0.06) 100%);
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .cta-section h2 {
      font-size: 2.8rem; font-weight: 800;
      background: linear-gradient(135deg, #fff, #bae6fd, var(--ocean-3));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 1rem;
    }
    .cta-section p { font-size: 1.1rem; color: #94a3b8; max-width: 640px; margin: 0 auto 2.5rem; line-height: 1.7; }

    /* ── BUTTONS ─────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.8rem 1.8rem; border-radius: 12px;
      background: linear-gradient(135deg, var(--ocean-1), var(--ocean-2));
      color: #fff; font-weight: 700; text-decoration: none;
      font-family: 'Outfit', sans-serif; border: none; cursor: pointer;
